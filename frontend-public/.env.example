# Public — shipped to client bundle
NEXT_PUBLIC_API_URL=http://localhost:8000

# Cloudflare Turnstile site key (public). Required for DownloadModal
# and InquiryForm to render their Turnstile challenges. Without it
# the widget silently renders null and form submission blocks.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-only — admin proxy uses this to forward requests
ADMIN_API_KEY=replace-me-with-the-backend-X-API-KEY-value

# Server-only — existing
REVALIDATION_SECRET=replace-me

# Public-facing site URL for canonical /p/{slug} links in publish kit.
# Mirrors backend's public_site_url Setting. Required for ZIP export of publish kit.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
