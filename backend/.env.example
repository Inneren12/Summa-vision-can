# === Database ===
# REQUIRED: Must be set to a non-empty value in all environments.
# DATABASE_URL host segment depends on how you run Postgres:
#   - api running directly on host (e.g. `uvicorn` outside compose): @localhost:5432
#   - api running inside compose (dev or prod):                       @db:5432
# Note: docker-compose.dev.yml maps host port 5432 for DBeaver/psql
# on your dev machine — that mapping is NOT used by the api container.
DATABASE_URL=postgresql+asyncpg://summa:devpassword@localhost:5432/summa
# POSTGRES_USER / POSTGRES_DB / POSTGRES_PASSWORD are REQUIRED by the
# compose `db` service. Compose fails fast on startup if any are unset.
POSTGRES_DB=summa
POSTGRES_USER=summa
POSTGRES_PASSWORD=devpassword

# === Storage ===
# The storage backend. Set to "local" or "s3"
STORAGE_BACKEND=s3
# REQUIRED: Name of the S3 bucket. Must be non-empty.
S3_BUCKET=summa-vision-dev
# URL of S3 endpoint. For dev it should be MinIO, empty for AWS
S3_ENDPOINT_URL=http://localhost:9000
# AWS Access Key ID
S3_ACCESS_KEY_ID=minioadmin
# AWS Secret Access Key
S3_SECRET_ACCESS_KEY=minioadmin
# AWS Region
S3_REGION=us-east-1
# REQUIRED in production: CDN base URL for public lowres assets.
CDN_BASE_URL=http://localhost:9000/summa-vision-dev
# Local storage directory when using local storage
LOCAL_STORAGE_DIR=./data/local_storage

# === Public Site ===
# REQUIRED in production: Public-facing site URL.
PUBLIC_SITE_URL=http://localhost:3000

# === Security ===
# REQUIRED: Must be set to a non-empty value in all environments.
ADMIN_API_KEY=dev-secret-key-change-in-production
# REQUIRED in production: Cloudflare Turnstile secret for bot protection.
# TURNSTILE_SECRET_KEY=

# === Application ===
# "development" (default) or "production".
# Production enforces additional secret validation (CDN_BASE_URL, PUBLIC_SITE_URL, TURNSTILE_SECRET_KEY).
ENVIRONMENT=development
DEBUG=true
LOG_FORMAT=console  # "console" for dev, "json" for production

# === Hard Caps (R15) — override defaults if needed ===
# MAX_PREVIEW_ROWS=100
# MAX_CHART_POINTS=500
# MAX_JOB_RETRIES=3

# === Backup ===
# Use a SEPARATE bucket from the main data bucket in production.
# This protects backups if the main bucket is accidentally purged.
BACKUP_S3_BUCKET=summa-vision-backups
BACKUP_RETENTION_DAYS=30
