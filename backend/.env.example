# === Database ===
DATABASE_URL=postgresql+asyncpg://summa:devpassword@localhost:5432/summa
POSTGRES_DB=summa
POSTGRES_USER=summa
POSTGRES_PASSWORD=devpassword

# === Storage ===
S3_BUCKET=summa-vision-dev
S3_ENDPOINT_URL=http://localhost:9000   # MinIO for dev, empty for AWS
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
CDN_BASE_URL=http://localhost:9000/summa-vision-dev
STORAGE_BACKEND=s3   # "s3" or "local"

# === Security ===
ADMIN_API_KEY=dev-secret-key-change-in-production
# GEMINI_API_KEY=           # Optional, not needed until LLM features
# TURNSTILE_SECRET_KEY=     # Not needed until Stage D

# === Application ===
DEBUG=true
LOG_FORMAT=console  # "console" for dev, "json" for production

# === Hard Caps (R15) — override defaults if needed ===
# MAX_PREVIEW_ROWS=100
# MAX_CHART_POINTS=500
# MAX_JOB_RETRIES=3
